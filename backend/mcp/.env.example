# Google Cloud key with the Solar API + Geocoding API enabled (billing must be on).
# Used for roof geometry (tilt / azimuth / area) and address -> lat/lon.
GOOGLE_MAPS_API_KEY=

# --- Auth: pick a mode (switchable on redeploy, no code change) ---
#   bearer  : shared-secret token (MAXNERGY_API_TOKEN). Claude Code / Anthropic API.
#   fastmcp : FastMCP is its own OAuth server (DCR + authorize + token), NO external
#             IdP. Lets the claude.ai web/desktop/mobile connector attach with zero
#             setup. Caveat: simulated consent (no real login) + in-memory state, so
#             it's effectively open access and re-auths after a redeploy.
#   google  : real Google login via OAuth proxy (genuine per-user access control);
#             needs GOOGLE_OAUTH_CLIENT_ID/SECRET and a Google Web OAuth client whose
#             redirect URI is  https://<your-domain>/auth/callback
MAXNERGY_AUTH_MODE=bearer

# Public https URL of the server (used by both OAuth modes for metadata/redirects).
# Auto-derived from RAILWAY_PUBLIC_DOMAIN on Railway if left unset.
PUBLIC_BASE_URL=

# Persist OAuth state (registered clients + tokens) to this file so the claude.ai
# connector's client_id survives redeploys/restarts. Point at a Railway volume mount,
# e.g. /data/oauth.json. Unset = in-memory (clients must re-auth after each deploy).
# Used by the 'passphrase' / 'fastmcp' self-hosted OAuth modes.
MAXNERGY_OAUTH_STATE_PATH=

# Used when MAXNERGY_AUTH_MODE=bearer. Empty = unauthenticated (local stdio).
# Generate:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MAXNERGY_API_TOKEN=

# Logging verbosity: INFO (default, normal flow) or DEBUG (adds internals).
# Logs go to stdout; Railway captures them in the deploy logs tab.
LOG_LEVEL=INFO

# Used when MAXNERGY_AUTH_MODE=google.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: stable JWT signing key so google-mode access tokens survive redeploys.
# Generate:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
MAXNERGY_JWT_SIGNING_KEY=

# Transport override (stdio|http). Auto: http when PORT is set (Railway), else stdio.
# MCP_TRANSPORT=http

# Optional default market assumptions (German single-family defaults if unset).
# MAXNERGY_ELECTRICITY_PRICE_EUR_PER_KWH=0.35
# MAXNERGY_FEED_IN_EUR_PER_KWH=0.08
