{
    "defaults":{
        "general_data_path":"src/core_specs/data/general_data.json"
    },
    
    "logging":{
        "logging_level":"debug",
        "dir_name":"logs",
        "log_file_name":"MAXergy_bcknd"
    },
    "email_validation":{
        "allowed_providers":["gmail","outlook","yahoo","hotmail","icloud","protonmail","aol","zoho","gmx","mail"],
        "allowed_tlds":["com", "org", "net", "co", "io", "edu", "gov"]
    },

    "network":{
        "uvicorn_app_reference": "main:app",
        "server_port":8000,
        "host": "0.0.0.0",
        "reload": false,
        "workers": 1,
        "proxy_headers": true
    },

    "endpoints": {
        "root_directory_endpoint":{
            "request_limit":25,
            "unit_of_time_for_limit":"m",
            "endpoint_prefix": "",
            "endpoint_tag":"root",
            "endpoint_route": "/"
        },
        
        "maxergy_assessment": {
            "request_limit": 10,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/assessment",
            "endpoint_tag": "assessment",
            "endpoint_route": ""
        },
        "maxergy_forecast": {
            "request_limit": 5,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/forecast",
            "endpoint_tag": "forecast",
            "endpoint_route": ""
        },
        "maxergy_recommendation": {
            "request_limit": 5,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/recommendation",
            "endpoint_tag": "recommendation",
            "endpoint_route": ""
        },
        "maxergy_advisor_chat": {
            "request_limit": 10,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/advisor",
            "endpoint_tag": "advisor",
            "endpoint_route": "/chat"
        },
        "maxergy_visualization": {
            "request_limit": 10,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/visualization",
            "endpoint_tag": "visualization",
            "endpoint_route": "/forecast-chart"
        }
    }
}