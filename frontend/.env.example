# Cloover frontend environment

# Base URL of the FastAPI backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000
# VITE_API_BASE_URL=http://deployed_backend.com

# When "true", endpoints return local fixtures instead of calling the backend.
# Set to "false" once your backend is running to use real /assessment, /forecast,
# /recommendation and /advisor/chat endpoints.
VITE_USE_MOCKS=true